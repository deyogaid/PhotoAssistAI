rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Hardened Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        request.auth.token.firebase.sign_in_provider == 'google.com'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    function isValidGeneration(data) {
      return data.userId == request.auth.uid &&
             data.input is map &&
             data.input.photoType is string &&
             data.result is map &&
             data.result.prompt is string &&
             data.createdAt == request.time;
    }

    function isValidPreset(data) {
      return data.userId == request.auth.uid &&
             data.name is string &&
             data.name.size() <= 100 &&
             data.config is map &&
             data.createdAt == request.time;
    }

    // --- Collection Matches ---
    match /generations/{genId} {
      allow list: if isVerified() && resource.data.userId == request.auth.uid;
      allow get: if isVerified() && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isValidGeneration(incoming());
      allow delete: if isVerified() && existing().userId == request.auth.uid;
    }

    match /user_presets/{presetId} {
      allow list: if isVerified() && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isValidPreset(incoming());
      allow delete: if isVerified() && existing().userId == request.auth.uid;
    }
  }
}
