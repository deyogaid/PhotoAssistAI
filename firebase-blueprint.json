{
  "entities": {
    "Generation": {
      "title": "Generation",
      "description": "Output data from AI studio assist for photographers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "input": {
          "type": "object",
          "properties": {
            "photoType": { "type": "string" },
            "subjectCount": { "type": "number" },
            "outfitColor": { "type": "string" },
            "conditions": { "type": "array", "items": { "type": "string" } },
            "targetStyle": { "type": "string" },
            "intensity": { "type": "number" }
          }
        },
        "result": {
          "type": "object",
          "properties": {
            "prompt": { "type": "string" },
            "creativeDirection": { "type": "string" },
            "imageUrl": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "input", "result", "createdAt"]
    },
    "UserPreset": {
      "title": "User Preset",
      "description": "User-defined photo generation configurations.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "config": {
          "type": "object",
          "properties": {
            "photoType": { "type": "string" },
            "targetStyle": { "type": "string" },
            "intensity": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "config", "createdAt"]
    }
  },
  "firestore": {
    "generations": {
      "schema": "Generation",
      "description": "Stored history of AI prompts and visual directions generated by photographers."
    },
    "user_presets": {
      "schema": "UserPreset",
      "description": "Custom presets saved by users or automatically created for new modes."
    }
  }
}
